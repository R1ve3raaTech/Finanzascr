# Copiar a .env.local y llenar con los valores del proyecto en https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Solo para procesos de servidor (sync de Gmail). Nunca exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=

# Client ID/Secret del OAuth Client de Google (Cloud Console > Credentials).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Secreto compartido para POST /api/sync-gmail (generar con: openssl rand -hex 24)
CRON_SECRET=

# Claves VAPID para notificaciones push (generar con: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:tu-correo@ejemplo.com
